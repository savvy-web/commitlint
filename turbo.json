{
	"$schema": "https://turborepo.com/schema.v2.json",
	"globalPassThroughEnv": ["GITHUB_ACTIONS", "CI"],
	"tasks": {
		"//#types:check": {
			"cache": true,
			"dependsOn": [],
			"inputs": [
				"$TURBO_DEFAULT$",
				"lib/**/*.ts",
				"src/**/*.ts",
				"!**/*.md",
				"!.changeset/**",
				"!.claude/**",
				"!.github/**",
				"!.husky/**",
				"!.vscode/**",
				"!.rslib/**",
				"!dist/**",
				"!.turbo/**"
			],
			"outputLogs": "errors-only",
			"outputs": []
		}
	}
}
