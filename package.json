{
	"name": "@savvy-web/commitlint",
	"version": "0.4.4",
	"private": true,
	"description": "Dynamic, intelligent commitlint configuration with auto-detection of DCO, workspace scopes, and versioning strategies.",
	"keywords": [
		"commitlint",
		"conventional-commits",
		"commit-lint",
		"git-hooks",
		"dco",
		"developer-certificate-of-origin",
		"monorepo",
		"workspaces",
		"effect-ts"
	],
	"homepage": "https://github.com/savvy-web/commitlint#readme",
	"bugs": {
		"url": "https://github.com/savvy-web/commitlint/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/savvy-web/commitlint.git"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@savvyweb.systems",
		"url": "https://savvyweb.systems"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./static": "./src/static.ts",
		"./prompt": "./src/prompt/index.ts",
		"./formatter": "./src/formatter/index.ts"
	},
	"bin": {
		"savvy-commit": "./src/bin/cli.ts"
	},
	"scripts": {
		"build": "turbo run build:dev build:prod --log-order=grouped --log-prefix=none",
		"build:dev": "rslib build --config-loader native --env-mode dev",
		"build:inspect": "rslib inspect --config-loader native --env-mode npm --verbose",
		"build:prod": "rslib build --config-loader native --env-mode npm",
		"ci:build": "CI=\"true\" turbo run build:dev build:prod --log-order=grouped --output-logs=full --log-prefix=none",
		"ci:test": "CI=\"true\" vitest run --coverage",
		"ci:version": "savvy-changesets version && biome format --write .",
		"commit": "cz",
		"lint": "biome check --max-diagnostics=none",
		"lint:fix": "biome check --write --max-diagnostics=none",
		"lint:fix:unsafe": "biome check --write --unsafe --max-diagnostics=none",
		"lint:md": "markdownlint-cli2 '**/*.{md,mdx}' --config './lib/configs/.markdownlint-cli2.jsonc'",
		"lint:md:fix": "markdownlint-cli2  --config './lib/configs/.markdownlint-cli2.jsonc' --fix",
		"prepare": "husky",
		"test": "vitest run",
		"test:ai": "vitest run --reporter=basic",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest --watch",
		"typecheck": "turbo run types:check --log-prefix=none --log-order=grouped",
		"types:check": "tsgo --noEmit"
	},
	"config": {
		"commitizen": {
			"path": "./dist/dev/prompt.js"
		}
	},
	"dependencies": {
		"@effect/cli": "catalog:silk",
		"@effect/cluster": "catalog:silk",
		"@effect/platform": "catalog:silk",
		"@effect/platform-node": "catalog:silk",
		"@effect/printer": "catalog:silk",
		"@effect/printer-ansi": "catalog:silk",
		"@effect/rpc": "catalog:silk",
		"@effect/sql": "catalog:silk",
		"effect": "catalog:silk",
		"workspace-tools": "0.41.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@commitlint/lint": "^20.4.3",
		"@commitlint/types": "^20.4.3",
		"@savvy-web/changesets": "^0.7.1",
		"@savvy-web/lint-staged": "^0.6.5",
		"@savvy-web/rslib-builder": "^0.19.1",
		"@savvy-web/vitest": "^1.0.1",
		"commitizen": "^4.3.1",
		"husky": "^9.1.7"
	},
	"peerDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"commitizen": "^4.3.1",
		"husky": "^9.1.0"
	},
	"peerDependenciesMeta": {
		"@commitlint/cli": {
			"optional": false
		},
		"@commitlint/config-conventional": {
			"optional": false
		},
		"commitizen": {
			"optional": false
		},
		"husky": {
			"optional": false
		}
	},
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "10.33.0",
			"onFail": "ignore"
		},
		"runtime": [
			{
				"name": "node",
				"version": "24.11.0",
				"onFail": "ignore"
			}
		]
	},
	"publishConfig": {
		"access": "public",
		"dist": "dist/dev",
		"linkDirectory": true,
		"targets": [
			{
				"protocol": "npm",
				"registry": "https://npm.pkg.github.com/",
				"directory": "dist/npm",
				"access": "public",
				"provenance": true
			},
			{
				"protocol": "npm",
				"registry": "https://registry.npmjs.org/",
				"directory": "dist/npm",
				"access": "public",
				"provenance": true
			}
		]
	}
}
