{
	"name": "@savvy-web/commitlint",
	"version": "0.6.0",
	"private": true,
	"description": "Dynamic, intelligent commitlint configuration with auto-detection of DCO, workspace scopes, and versioning strategies.",
	"keywords": [
		"commitlint",
		"conventional-commits",
		"commit-lint",
		"git-hooks",
		"dco",
		"developer-certificate-of-origin",
		"monorepo",
		"workspaces",
		"effect-ts"
	],
	"homepage": "https://github.com/savvy-web/commitlint/tree/main/package#readme",
	"bugs": {
		"url": "https://github.com/savvy-web/commitlint/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/savvy-web/commitlint.git",
		"directory": "package"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@savvyweb.systems",
		"url": "https://savvyweb.systems"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./static": "./src/static.ts",
		"./prompt": "./src/prompt/index.ts",
		"./formatter": "./src/formatter/index.ts"
	},
	"bin": {
		"savvy-commit": "./src/bin/cli.ts"
	},
	"scripts": {
		"build:dev": "rslib build --env-mode dev",
		"build:prod": "rslib build --env-mode npm",
		"prepare": "rslib build --config-loader native --env-mode dev",
		"types:check": "tsgo --noEmit"
	},
	"dependencies": {
		"@effect/cli": "catalog:silk",
		"@effect/cluster": "catalog:silk",
		"@effect/platform": "catalog:silk",
		"@effect/platform-node": "catalog:silk",
		"@effect/printer": "catalog:silk",
		"@effect/printer-ansi": "catalog:silk",
		"@effect/rpc": "catalog:silk",
		"@effect/sql": "catalog:silk",
		"@savvy-web/silk-effects": "^0.3.0",
		"effect": "catalog:silk",
		"shell-quote": "^1.8.3",
		"workspaces-effect": "^0.5.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.2",
		"@commitlint/config-conventional": "^20.5.0",
		"@commitlint/lint": "^20.5.0",
		"@commitlint/types": "^20.5.0",
		"@savvy-web/rslib-builder": "^0.20.3",
		"@types/node": "catalog:silk",
		"@types/shell-quote": "^1.7.5",
		"@typescript/native-preview": "catalog:silk",
		"commitizen": "^4.3.1",
		"husky": "^9.1.7",
		"typescript": "catalog:silk"
	},
	"peerDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"commitizen": "^4.3.0",
		"husky": "^9.1.0"
	},
	"peerDependenciesMeta": {
		"@commitlint/cli": {
			"optional": false
		},
		"@commitlint/config-conventional": {
			"optional": false
		},
		"commitizen": {
			"optional": false
		},
		"husky": {
			"optional": false
		}
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev",
		"linkDirectory": true,
		"targets": [
			{
				"protocol": "npm",
				"registry": "https://npm.pkg.github.com/",
				"directory": "dist/npm",
				"access": "public",
				"provenance": true
			},
			{
				"protocol": "npm",
				"registry": "https://registry.npmjs.org/",
				"directory": "dist/npm",
				"access": "public",
				"provenance": true
			}
		]
	}
}
